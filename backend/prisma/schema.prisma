generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions       Session[]
  brandProfile   BrandProfile?
  subscriptions  Subscription[]
  creditLedgers  CreditLedger[]
  contentInputs  ContentInput[]
  generationJobs GenerationJob[]
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String
  ipAddress        String
  userAgent        String
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
}

model BrandProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  niche          String
  targetAudience String
  coreExpertise  String
  offerDetails   String
  tone           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                    String           @id @default(uuid())
  userId                String
  razorpaySubscriptionId String          @unique
  plan                  SubscriptionPlan
  interval              SubscriptionInterval
  status                SubscriptionStatus
  currentPeriodEnd      DateTime
  monthlyCreditLimit    Int
  creditsUsed           Int              @default(0)
  extraCredits          Int              @default(0)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([razorpaySubscriptionId])
}

model CreditLedger {
  id          String           @id @default(uuid())
  userId      String
  type        CreditLedgerType
  amount      Int
  description String
  referenceId String?
  metadata    Json?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([referenceId])
}

model ContentInput {
  id          String          @id @default(uuid())
  userId      String
  type        ContentInputType
  topic       String?
  idea        String?
  transcript  String?
  createdAt   DateTime        @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJobs GenerationJob[]

  @@index([userId])
  @@index([createdAt])
}

model GenerationJob {
  id              String             @id @default(uuid())
  userId          String
  contentInputId  String
  status          GenerationJobStatus @default(PENDING)
  creditsConsumed Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  errorMessage    String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentInput ContentInput @relation(fields: [contentInputId], references: [id], onDelete: Cascade)
  generatedPosts GeneratedPost[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([contentInputId])
}

model GeneratedPost {
  id             String          @id @default(uuid())
  jobId          String
  content        String
  structureType  PostStructureType
  orderIndex     Int
  createdAt      DateTime        @default(now())

  job GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@unique([jobId, orderIndex])
}

model PaymentEvent {
  id              String   @id @default(uuid())
  razorpayEventId String   @unique
  type            String
  payload         Json
  createdAt       DateTime @default(now())
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionPlan {
  BASIC
  PROFESSIONAL
  AUTHORITY
}

enum SubscriptionInterval {
  MONTHLY
  ANNUAL
}

enum CreditLedgerType {
  SUBSCRIPTION_CREDIT
  GENERATION_DEDUCTION
  GENERATION_REFUND
  EXTRA_CREDIT_PURCHASE
  ADMIN_ADJUSTMENT
  SIGNUP_BONUS
  ACTIVATION_BONUS
}

enum ContentInputType {
  QUICK
  REPURPOSE
}

enum GenerationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PostStructureType {
  HOOK_INSIGHT
  STORY_LESSON
  LIST
  CONTRARIAN
  EDUCATIONAL
  FRAMEWORK
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}